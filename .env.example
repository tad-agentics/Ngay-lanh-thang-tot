# Environment Variables — Ngày Lành Tháng Tốt (ngaylanhthangtot.vn)
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.

# ─── Supabase (required) ───────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=              # Server-only — Edge Functions only, never in frontend

# ─── PayOS (northstar §11 — Vietnam payments) ─────────────────────────
# Server-only — Edge Functions / webhook verification
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# ─── Resend (if product sends transactional email) ─────────────────────
# RESEND_API_KEY=                        # Server-only — Edge Functions only

# ─── LLM (if product uses AI features) ────────────────────────────────
# ANTHROPIC_API_KEY=                     # Server-only — Edge Functions only
# OPENAI_API_KEY=                        # Server-only — Edge Functions only

# Add project-specific variables below this line
# ---

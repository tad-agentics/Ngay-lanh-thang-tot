# Environment Variables — Ngày Lành Tháng Tốt
# Copy to .env.local — never commit secrets.

# ─── Supabase (client) ───────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ─── Supabase (Edge Functions — supabase secrets set) ─────────────────────
SUPABASE_SERVICE_ROLE_KEY=

# ─── PayOS (Edge only) ─────────────────────────────────────────────────────
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# ─── Gemini (Edge: generate-reading only) ────────────────────────────────
# supabase secrets set GEMINI_API_KEY=AIza…
# Optional: supabase secrets set GEMINI_MODEL=gemini-3.1-flash-lite
# Optional: supabase secrets set GEMINI_THINKING_BUDGET=0   # 0 = tắt thinking (mặc định, nhanh + rẻ)
# Missing key → EF still 200, reading: null
GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_THINKING_BUDGET=

# ─── Bát Tự API (Edge only) ──────────────────────────────────────────────
# Remote: supabase secrets set BAT_TU_API_URL=… BAT_TU_API_KEY=…
# Local serve: supabase/functions/.env (same keys; file is gitignored)
# URL = API origin only: https://tu-tru-api.fly.dev — NOT /docs, NOT Swagger hash links
# (see https://tu-tru-api.fly.dev/docs only in browser; Edge strips /docs and #fragments if mis-pasted).
BAT_TU_API_URL=https://tu-tru-api.fly.dev
BAT_TU_API_KEY=

# ─── App URL (client) ─────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173

# ─── Share HMAC (Edge only) ────────────────────────────────────────────────
SHARE_TOKEN_SECRET=

# ─── Cron / internal triggers (Edge only, optional) ───────────────────────
CRON_SECRET=

# ─── Misc ─────────────────────────────────────────────────────────────────
# UI_REFERENCE_REPO=skip

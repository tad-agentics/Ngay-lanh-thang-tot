# Environment Variables — Ngày Lành Tháng Tốt
# Copy to .env.local — never commit secrets.

# ─── Supabase (client) ───────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ─── Supabase (Edge Functions — supabase secrets set) ─────────────────────
SUPABASE_SERVICE_ROLE_KEY=
# App origin for CORS + PayOS return/cancel URL allowlist (must match VITE_APP_URL in each env)
# supabase secrets set ALLOWED_ORIGIN=https://ngaylanhthangtot.vn
# Local: supabase secrets set ALLOWED_ORIGIN=http://localhost:5173
ALLOWED_ORIGIN=

# ─── PayOS (Edge only) ─────────────────────────────────────────────────────
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# ─── DeepSeek (Edge: generate-reading-day | -la-so | -tieu-van) ─────────
# OpenAI-compatible: https://api.deepseek.com/chat/completions
# Apply key: https://platform.deepseek.com/api_keys
# supabase secrets set DEEPSEEK_API_KEY=sk-…
# Optional: supabase secrets set DEEPSEEK_MODEL=deepseek-v4-flash
# Optional: supabase secrets set DEEPSEEK_MODEL_PRO=deepseek-v4-pro
#   → chỉ la-so-chi-tiet (Bát Tự năm) + tieu-van / luu-nien
# Optional: supabase secrets set DEEPSEEK_THINKING=disabled  # chỉ flash (ngày, hợp tuổi, …)
# Pro luôn thinking on. Default flash: thinking enabled.
# Optional: supabase secrets set DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_MODEL_PRO=
# Missing key → EF still 200, reading: null
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
DEEPSEEK_THINKING=
DEEPSEEK_REASONING_EFFORT=

# ─── Bát Tự API (Edge only) ──────────────────────────────────────────────
# Remote: supabase secrets set BAT_TU_API_URL=… BAT_TU_API_KEY=…
# Local serve: supabase/functions/.env (same keys; file is gitignored)
# URL = API origin only: https://tu-tru-api.fly.dev — NOT /docs, NOT Swagger hash links
# (see https://tu-tru-api.fly.dev/docs only in browser; Edge strips /docs and #fragments if mis-pasted).
BAT_TU_API_URL=https://tu-tru-api.fly.dev
BAT_TU_API_KEY=

# ─── App URL (client) ─────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173

# ─── Sentry (client — production error reporting) ─────────────────────────
# Vercel production: Project → Client Keys (DSN). Dev: leave empty.
VITE_SENTRY_DSN=

# ─── Share HMAC (Edge only) ────────────────────────────────────────────────
SHARE_TOKEN_SECRET=

# ─── Cron / internal triggers (Edge only, optional) ───────────────────────
CRON_SECRET=

# ─── Misc ─────────────────────────────────────────────────────────────────
# UI_REFERENCE_REPO=skip
